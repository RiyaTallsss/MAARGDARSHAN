# AI-Powered Rural Infrastructure Planning System
# Environment Configuration Template
#
# Copy this file to .env and fill in your actual API keys and credentials

# =============================================================================
# Weather APIs
# =============================================================================

# OpenWeatherMap API (Free tier: 1000 calls/day)
# Get your key at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# India Meteorological Department API
# Contact IMD for access: https://mausam.imd.gov.in/
IMD_API_KEY=your_imd_api_key_here

# NASA POWER API (Free access)
# No key required for basic access
NASA_POWER_API_KEY=

# =============================================================================
# Geospatial APIs
# =============================================================================

# NASA SRTM API (Free access)
# No key required for basic access
NASA_SRTM_API_KEY=

# USGS Elevation API (Free access)
# No key required for basic access
USGS_ELEVATION_API_KEY=

# Mapbox API (Optional, for enhanced terrain data)
# Get your key at: https://www.mapbox.com/
MAPBOX_API_KEY=your_mapbox_api_key_here

# =============================================================================
# Infrastructure APIs
# =============================================================================

# Google Places API (Paid service)
# Get your key at: https://developers.google.com/places/web-service/get-api-key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Sentinel Hub API (Freemium model)
# Get your key at: https://www.sentinel-hub.com/
SENTINEL_HUB_API_KEY=your_sentinel_hub_api_key_here

# =============================================================================
# Disaster Management APIs
# =============================================================================

# India Disaster Management API
# Contact NDMA for access: https://ndma.gov.in/
INDIA_DISASTER_API_KEY=your_disaster_api_key_here

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS Credentials for Bedrock access
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Amazon Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# S3 Configuration (Optional, for data storage)
S3_BUCKET_NAME=your_s3_bucket_name

# =============================================================================
# System Configuration
# =============================================================================

# Data directories (relative to project root)
DATA_ROOT=.
CACHE_DIRECTORY=cache

# Cache settings
CACHE_EXPIRY_HOURS=24
MAX_CACHE_SIZE_MB=1000

# Logging configuration
LOG_LEVEL=INFO
DEBUG_MODE=false

# Performance settings
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT_SECONDS=30

# =============================================================================
# Development Settings
# =============================================================================

# Enable profiling for performance analysis
ENABLE_PROFILING=false

# Database URL (if using database for caching)
# DATABASE_URL=sqlite:///rural_planning.db

# =============================================================================
# API Rate Limiting (requests per minute)
# =============================================================================

# Adjust these based on your API plan limits
OPENWEATHERMAP_RATE_LIMIT=60
OVERPASS_RATE_LIMIT=10
NASA_SRTM_RATE_LIMIT=100
GOOGLE_PLACES_RATE_LIMIT=100
SENTINEL_HUB_RATE_LIMIT=20